				function = "qup2_se6";
				drive-strength = <6>;
				bias-disable;
			};

			qup_spi14_data_clk: qup-spi14-data-clk-state {
				/* MISO, MOSI, CLK */
				pins = "gpio20", "gpio21", "gpio22";
				function = "qup2_se6";
				drive-strength = <6>;
				bias-disable;
			};

			qup_i2c15_data_clk: qup-i2c15-data-clk-state {
				pins = "gpio27", "gpio26";
				function = "qup2_se7";
				drive-strength = <2>;
				bias-pull-up;
			};

