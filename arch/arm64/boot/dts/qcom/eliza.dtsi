				function = "qup2_se5";
				drive-strength = <2>;
				bias-pull-up;
			};

			qup_i2c14_data_clk: qup-i2c14-data-clk-state {
				pins = "gpio20", "gpio21";
				function = "qup2_se6";
				drive-strength = <2>;
				bias-pull-up;
