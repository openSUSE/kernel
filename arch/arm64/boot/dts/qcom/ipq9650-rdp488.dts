/dts-v1/;

#include "ipq9650.dtsi"

/ {
	model = "Qualcomm Technologies, Inc. IPQ9650 RDP488";
	compatible = "qcom,ipq9650-rdp488", "qcom,ipq9650";

	aliases {
		serial0 = &uart1;
	};

	chosen {
		stdout-path = "serial0";
	};
};

&sdhc {
	max-frequency = <192000000>;
	bus-width = <4>;
	mmc-ddr-1_8v;
	mmc-hs200-1_8v;
	pinctrl-0 = <&sdhc_default_state>;
	pinctrl-names = "default";

	status = "okay";
};

&sleep_clk {
	clock-frequency = <32000>;
};

&tlmm {
	qup_uart1_default_state: qup-uart1-default-state {
		pins = "gpio43", "gpio44";
		function = "qup_se6";
		drive-strength = <8>;
		bias-pull-down;
	};

	sdhc_default_state: sdhc-default-state {
		clk-pins {
			pins = "gpio5";
			function = "sdc_clk";
			drive-strength = <8>;
			bias-disable;
		};

		cmd-pins {
			pins = "gpio4";
			function = "sdc_cmd";
			drive-strength = <8>;
			bias-pull-up;
		};

		data-pins {
			pins = "gpio0", "gpio1", "gpio2", "gpio3";
			function = "sdc_data";
			drive-strength = <8>;
			bias-pull-up;
		};
	};
};

&uart1 {
	pinctrl-0 = <&qup_uart1_default_state>;
	pinctrl-names = "default";

	status = "okay";
};

&xo_board {
	clock-frequency = <24000000>;
};
